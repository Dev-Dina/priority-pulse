# ── Qdrant (vector store) ─────────────────────────────────────────────────
# Locally: localhost. Inside Docker Compose: use the service name "qdrant"
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tickets

# ── LLM ───────────────────────────────────────────────────────────────────
# Primary provider: Google Gemini (free tier at aistudio.google.com)
GEMINI_API_KEY=
# Fallback provider: Groq — OpenAI-compatible, open-weight models (console.groq.com)
GROQ_API_KEY=

# ── Application ───────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_TO_FILE=true
LOG_TO_DB=false

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
